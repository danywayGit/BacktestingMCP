# =============================================================================
# Edge Scanner — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Required: ALTFINS_API_KEY, TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID
# Optional: OPENROUTER_API_KEY (for auto-evolver)

# ── altFINS MCP ─────────────────────────────────────────────────────────────
# Required for chart pattern scanning and signal aggregation.
ALTFINS_API_KEY="your_altfins_api_key_here"

# ── Telegram Alerts ─────────────────────────────────────────────────────────
# Required for sending reports to your crypto alerts channel.
# Get token from @BotFather, chat ID from your channel.
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CHAT_ID="-1000000000000"

# ── OpenRouter (LLM auto-evolver) ───────────────────────────────────────────
# Optional. Required for the "edge auto-evolve" command.
# Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# ── Webhook Bridge (Trading-WebHook-Bot) ────────────────────────────────────
# Required for automated signal execution.
WEBHOOK_URL="http://your-server-ip:80/webhook"
WEBHOOK_KEY="your_webhook_secret_key_here"

# ── Database ────────────────────────────────────────────────────────────────
# Path is relative to the BacktestingMCP directory.
DB_PATH="data/crypto.db"